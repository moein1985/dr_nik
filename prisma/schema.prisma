generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  STAFF
  DOCTOR
  SUPER_ADMIN
  CONTENT_MANAGER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ChatSessionStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum FreshPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String          @id @default(uuid())
  phoneNumber   String?         @unique
  username      String?         @unique
  email         String?         @unique
  avatarUrl     String?
  role          UserRole        @default(PATIENT)
  passwordHash  String
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
  doctorAppointments  Appointment[] @relation("AppointmentDoctor")
  sessions      Session[]
  passwordResets PasswordReset[]
  doctorProfile DoctorProfile?
  doctorStaffAssignmentsAsDoctor DoctorStaffAssignment[] @relation("DoctorAssignments")
  doctorStaffAssignmentsAsStaff  DoctorStaffAssignment[] @relation("StaffAssignments")
  chatSessionsAsPatient ChatSession[] @relation("ChatSessionPatient")
  chatSessionsAsDoctor  ChatSession[] @relation("ChatSessionDoctor")
  doctorAvailability    DoctorAvailability[] @relation("DoctorAvailability")
  doctorServices        DoctorService[] @relation("DoctorServices")
  freshPosts            FreshPost[] @relation("FreshPostAuthor")
  freshLikes            FreshLike[] @relation("FreshLikes")
  freshComments         FreshComment[] @relation("FreshComments")
}

model DoctorProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  aboutMe            String?
  credentials        String?
  acceptedInsurances String?
  workingHours       String?
  specialties        String?
  services           String?
  branchAddress      String?
  experience         String?
  extraNotes         String?
  aiProfileContext   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorAvailability {
  id           String   @id @default(uuid())
  doctorUserId String
  weekday      Int
  startMinute  Int
  endMinute    Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  doctor       User     @relation("DoctorAvailability", fields: [doctorUserId], references: [id], onDelete: Cascade)

  @@index([doctorUserId, weekday, isActive])
}

model DoctorService {
  id           String   @id @default(uuid())
  doctorUserId String
  serviceKey   String
  serviceLabel String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  doctor       User     @relation("DoctorServices", fields: [doctorUserId], references: [id], onDelete: Cascade)

  @@unique([doctorUserId, serviceKey])
  @@index([doctorUserId, isActive])
}

model Appointment {
  id              String            @id @default(uuid())
  createdByUserId String
  doctorUserId    String?
  patientName     String
  patientPhone    String
  doctorName      String
  requestedAt     DateTime
  serviceName     String
  notes           String?
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  createdBy       User              @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  doctor          User?             @relation("AppointmentDoctor", fields: [doctorUserId], references: [id], onDelete: SetNull)
  auditLogs       AppointmentAuditLog[]

  @@index([createdByUserId])
  @@index([doctorUserId])
  @@index([requestedAt])
  @@index([status, requestedAt])
}

model AppointmentAuditLog {
  id            String      @id @default(uuid())
  appointmentId String?
  action        String
  actorUserId   String
  actorRole     UserRole
  beforeJson    String?
  afterJson     String?
  createdAt     DateTime    @default(now())
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([appointmentId])
  @@index([actorUserId])
}

model DoctorStaffAssignment {
  id           String   @id @default(uuid())
  doctorUserId String
  staffUserId  String
  isActive     Boolean  @default(true)
  assignedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  doctor       User     @relation("DoctorAssignments", fields: [doctorUserId], references: [id], onDelete: Cascade)
  staff        User     @relation("StaffAssignments", fields: [staffUserId], references: [id], onDelete: Cascade)

  @@unique([doctorUserId, staffUserId])
  @@index([doctorUserId, isActive])
  @@index([staffUserId, isActive])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  userRole  UserRole
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id          String   @id @default(uuid())
  userId      String
  otpCodeHash String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Video {
  id          String   @id @default(uuid())
  title       String
  url         String
  coverImage  String?
  doctorSlug  String
  createdAt   DateTime @default(now())

  @@index([doctorSlug])
}

enum MediaStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model Media {
  id        String      @id @default(uuid())
  title     String
  url       String
  category  String
  status    MediaStatus @default(PENDING)
  createdAt DateTime    @default(now())

  @@index([status])
  @@index([category])
}

model AiProviderSetting {
  id        String   @id @default(uuid())
  provider  String
  model     String
  apiKey    String
  baseUrl   String?
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id            String            @id @default(uuid())
  patientUserId String
  doctorUserId  String
  status        ChatSessionStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  messages      ChatMessage[]
  patient       User              @relation("ChatSessionPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  doctor        User              @relation("ChatSessionDoctor", fields: [doctorUserId], references: [id], onDelete: Cascade)

  @@unique([patientUserId, doctorUserId])
  @@index([patientUserId])
  @@index([doctorUserId])
  @@index([status])
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatMessage {
  id        String          @id @default(uuid())
  sessionId String
  role      ChatMessageRole
  content   String
  createdAt DateTime        @default(now())
  session   ChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, role])
  @@index([createdAt])
}

model FreshPost {
  id           String          @id @default(uuid())
  authorUserId String
  mediaType    String
  mediaUrl     String
  caption      String?
  status       FreshPostStatus @default(PUBLISHED)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  author       User            @relation("FreshPostAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  likes        FreshLike[]
  comments     FreshComment[]

  @@index([authorUserId])
  @@index([status, createdAt])
}

model FreshLike {
  id        String    @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime  @default(now())
  post      FreshPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation("FreshLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model FreshComment {
  id        String    @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime  @default(now())
  post      FreshPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation("FreshComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}
