# App
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dr_nik_clinic

# SMTP (Mailpit local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Recipient for internal notifications
STAFF_NOTIFICATION_EMAIL=staff@drnikclinic.local

# Default admin bootstrap
DEFAULT_SUPER_ADMIN_USERNAME=superadmin
DEFAULT_SUPER_ADMIN_PASSWORD=SuperAdmin123!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123!

# OTP password reset
OTP_TTL_MINUTES=5
SMS_PROVIDER=mock

# Kavenegar (optional, only when SMS_PROVIDER=kavenegar)
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=verify

# Session
SESSION_COOKIE_NAME=drnik_session
SESSION_TTL_HOURS=24
SESSION_COOKIE_SECURE=false
