# Patch build: reuses node_modules from existing image, only rebuilds Next.js app
# Usage on server: docker build -f Dockerfile.patch -t dr_nik_clinic-app:redeploy-fresh-fix .

FROM dr_nik_clinic-app:latest AS builder
WORKDIR /workspace/clinic
COPY src/ ./src/
COPY public/ ./public/
COPY prisma/ ./prisma/
COPY next.config.ts tsconfig.json tailwind.config.ts postcss.config.js global.d.ts next-env.d.ts package.json ./
ENV DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dr_nik_clinic
ENV SMTP_HOST=mailpit
ENV SMTP_PORT=1025
ENV SMTP_SECURE=false
ENV STAFF_NOTIFICATION_EMAIL=staff@drnikclinic.local
ENV NODE_ENV=production
RUN npx prisma generate && rm -rf .next && npm run build

FROM dr_nik_clinic-app:latest
COPY --from=builder /workspace/clinic/.next ./.next
COPY --from=builder /workspace/clinic/public ./public
COPY --from=builder /workspace/clinic/prisma ./prisma
COPY --from=builder /workspace/clinic/node_modules/.prisma ./node_modules/.prisma
